# PostgreSQL (уже стоит на сервере). Формат psycopg v3:
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/lifeasgame

# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Твой Telegram chat_id (узнать у @userinfobot). Бот отвечает только этому пользователю.
OWNER_CHAT_ID=000000000

# Таймзона для напоминаний и отчётов
TZ=Europe/Moscow

# Прокси для Telegram, если API заблокирован (необязательно).
# Локальный SOCKS5 от Xray-клиента, например:
# PROXY_URL=socks5://127.0.0.1:10808
